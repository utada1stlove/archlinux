# Copy this file to config.env and adjust as needed.
# cp config.env.example config.env

TARGET_HOST="192.168.100.1"
TARGET_PORT="19798"

# Your rclone remote name, keep the trailing colon.
# Example: cloudrive:
RCLONE_REMOTE="clouddrive:"

# Local mount point.
MOUNT_POINT="$HOME/CloudDrive"

# Poll interval (seconds) for watch mode.
CHECK_INTERVAL_SEC="20"

# TCP connect timeout (seconds).
CONNECT_TIMEOUT_SEC="2"

# rclone log file
LOG_FILE="$HOME/.cache/rclone-clouddrive.log"

# Extra args passed to `rclone mount`.
# Add flags as one line string, e.g.:
# RCLONE_EXTRA_ARGS="--allow-other --vfs-cache-mode full --dir-cache-time 10m"
RCLONE_EXTRA_ARGS="--vfs-cache-mode full --dir-cache-time 10m"
